# AUTH TYPES
type AuthPayload {
    token: String
    role: String
    email: String
    message: String
}

type UserPayload {
    id: ID!
    email: String!
    role: String!
}

type CreationPayload {
    email: String!
    message: String!
}

type User {
    id: ID!
    email: String!
    role: String!
}

#  BILLING TYPES 
type InvoiceDto {
    invoiceId: String
    invoiceName: String
    status: String
    invoiceDate: String
    dueDate: String
    billingPeriodStart: String
    billingPeriodEnd: String
    totalAmount: Float
    amountDue: Float
    currency: String
    downloadUrl: String
}

type TestCostResult {
    meterName: String!
    serviceName: String!
    cost: Float!
}



type MonthlyCost {
    id: ID!
    month: Int!
    year: Int!
    meterName: String!
    serviceName: String!
    cost: Float!
    vmId: ID
    isShared: Boolean!
    resourceCategory: String
    currency: String!
    syncedAt: String!
}

type Reservation {
    reservationId: String!
    reservationOrderId: String!
    displayName: String!
    vmType: String!
    term: String!
    provisioningState: String!
    expiryDateTime: String
    purchaseDateTime: String
}

type AzureAlert {
    id: ID!
    azureAlertId: String!
    alertName: String!
    severity: String!
    description: String
    occurredAt: String!
    vmId: ID!
    vmName: String!
    monitorCondition: String!
    resolvedAt: String
    alertRule: String
    correlationId: String
    firedAlertId: ID
    durationSeconds: Int
    metricName: String
    metricNamespace: String
    metricValue: Float
    operator: String
    threshold: Float
}

type SchedulerStatus {
    cronExpression: String!
    lastExecution: String
    lastStatus: String!
    nextExecution: String
}

type SchedulerStatusMap {
    performance: SchedulerStatus!
    backup: SchedulerStatus!
    invoice: SchedulerStatus!
    infra: SchedulerStatus!
    alert: SchedulerStatus!
    monthlyCost: SchedulerStatus!
}

type VmPublicIp {
    id: ID!
