    monthsSynced: Int!
    monthsAlreadyPresent: Int!
    errors: Int!
}

type MonthResult {
    month: Int!
    year: Int!
    status: String!
    message: String!
}

type TotalCostForVmsResponse {
    totalAmount: Float!
    breakdown: [MonthlyBreakdown!]!
    vmDetails: [VmCostDetail!]!
}

type MonthlyBreakdown {
    month: String!
    amount: Float!
}

type VmCostDetail {
    vmId: ID!
    vmName: String!
    totalAmount: Float!
}

type VmDiskInfoDto {
    vmName: String
    workspaceName: String
    diskFreePercent: Float
    diskFreeMB: Float
    diskFreeGB: Float
    diskLastUpdated: String
}

    #  MUTATIONS
type Mutation {
    # Auth
    login(email: String!, password: String!): AuthPayload!
    verifyOtp(email: String!, otp: String!): AuthPayload!
    createUser(email: String!, role: String!): CreationPayload!
    changePassword(oldPassword: String!, newPassword: String!): AuthPayload!
    forgetPassword(email: String!): AuthPayload!
    verifyResetOtp(email: String!, otp: String!): AuthPayload!
    resetPassword(email: String!, otp: String!, newPassword: String!): AuthPayload!
    logout: AuthPayload!

    # Azure Sync
    syncAzureInfrastructure: String
    triggerMetricsSync: String
    triggerAlertSync: String
    triggerCostSync: String

    # Invoice
    savePreviousMonthInvoice: String
    saveLast12MonthsInvoices: String
    saveInvoicesFromDateRange(startYear: Int!, startMonth: Int!, endYear: Int!, endMonth: Int!): String

    # MonthlyCost
    syncMonthlyCosts(year: Int!, month: Int!): String!

    # Month VM Cost
    calculateMonthlyVmCosts(year: Int!, month: Int!): String!

    # Update vm Billing Type
    updateVmBillingType(vmId: ID!, billingType: String!): Boolean!

    # Active Reservation
    syncActiveReservations: String!

    triggerAlertSyncLast30Days: String

    # Scheduler update
    updateScheduler(task: String!, cronExpression: String!): String!

    # update domain name for vm
    updateVmDomainName(vmId: ID!, domainName: String!): String!

    # Backup Mutation
    syncBackupData: String!

    syncBackupHistoryLast30Days: String!

    syncMissingMonthlyCosts(
        startMonth: Int!
        startYear: Int!
        endMonth: Int!
        endYear: Int!
    ): MissingMonthsResponse!
}

#  QUERIES 
type Query {
    # Auth
    me: User!
    getAllUsers: [UserPayload!]!

    # Azure
    azureResources: [String]
    getAllProjectTags: [String]
    testAzureConnection: String

    # Billing
    invoicesForMonth(year: Int!, month: Int!): [InvoiceDto]
    invoicesBySmartIndex(index: Int! = 0): InvoicePageResponse!
    costAmounts(startMonth: Int!, startYear: Int!, endMonth: Int!, endYear: Int!): CostAmountsResponse!

    # Monthly Cost
    monthlyCosts(year: Int!, month: Int!): [MonthlyCost!]!
    getTotalCostsByService(year: Int!, month: Int!): [CostByService!]!
    getTotalCostsByMeter(year: Int!, month: Int!): [CostByMeter!]!
    getVmCostHistory(index: Int!): VmCostHistoryResponse!
    getVmCostsByMonthAndYear(year: Int, month: Int): [VmCostByMonth!]!
    vmCosts(vmId: ID!, year: Int!, month: Int!): [MonthlyCost!]!
    sharedCosts(year: Int!, month: Int!): [MonthlyCost!]!

    #Scheduler get
    getAllSchedules: SchedulerStatusMap!

    # public ip and domain name list
    getAllVmsWithPublicIp: [VmPublicIp!]!

    # infrastructure query
    getAllInfrastructure: InfrastructureResponse!

    # Reservation Queries
    getActiveReservationsWithLinkedVms: [ReservationWithVms!]!

    # Performance queries
    getVmPerformance(vmId: ID!
        startDate: String!
        endDate: String!
    ): VmPerformanceResponse!
    getVmPerformanceSummary(
        vmId: ID!
        startDate: String!
        endDate: String!
    ): VmPerformanceSummary!

    getVmAvailableRam(
        vmId: ID!
        startDate: String!
        endDate: String!
    ): VmAvailableRamResponse!

    # Alerts
    alertsByVmId(
        vmId: ID!
        index: Int!
    ): AlertPageResponse!

    alertSummary(
        vmId: ID!
        startDate: String!
        endDate: String!
    ): AlertSummaryResponse!

    alertHeatmap(
        vmId: ID!
    ): AlertHeatmapResponse!

    getVmDailyCpu(
        vmId: ID!
        date: String!
    ): VmDailyCpuResponse!

    getVmDailyRam(
        vmId: ID!
        date: String!
    ): VmDailyRamResponse!

    getVmDailyAvailableRam(
        vmId: ID!
        date: String!
    ): VmDailyAvailableRamResponse!

    getVmMetricTotal(
        vmId: ID!
        startDate: String!
        endDate: String!
        metricType: MetricType!
    ): VmMetricTotalResponse!

    getSharedCostsByService(
        year: Int!
        month: Int!
    ): SharedCostsResponse!

    getVmCostDetail(
        vmId: ID!
        year: Int!
        month: Int!
    ): VmCostDetailDto!

    getVmCostsByServiceForVm(
        vmId: ID!
        year: Int!
        month: Int!
    ): [VmCostByServiceDto!]!

    getVmCostHistoryByDateRange(
        vmId: ID!
        startDate: String!
        endDate: String!
    ): VmCostHistoryDto!

    getMonthlyCostsByDateRange(
        vmId: ID!
        startDate: String!
        endDate: String!
    ): MonthlyCostRangeResponse!

    getCostsByServiceName(startDate: String!, endDate: String!, serviceName: String!): ServiceCostsResponse!

    getAllBackupVaults: [BackupVault!]!
    getBackupVaultByName(vaultName: String!): BackupVault
    getProtectedItemsByStatus(protectionStatus: String!): [ProtectedItem!]!
    getVmBackupHistoryByDateRange(vmId: ID!, startDate: String!, endDate: String!): VmBackupHistoryResponse!
    getAllBackupVaultsWithItems: [BackupVaultWithItems!]!

    getDiskSizeAtTime(vmName: String!, timestamp: String!): DiskSizeAtTimeResponse!

    getTotalCostForVms(
        vmIds: [ID!]!
        startMonth: Int!
        startYear: Int!
        endMonth: Int!
        endYear: Int!
    ): TotalCostForVmsResponse!

    getVmDiskInfoById(vmId: Int!): VmDiskInfoDto
}