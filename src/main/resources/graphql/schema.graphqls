}

type BackupJobHistory {
    id: ID!
    jobId: String!
    jobName: String
    operation: String
    status: String
    startTime: String
    endTime: String
    duration: String
    isUserTriggered: Boolean
    errorCode: String
    errorMessage: String
    syncedAt: String
}

type ProtectedItem {
    id: ID!
    dataSourceName: String
    dataSourceType: String
    friendlyName: String
    policyName: String
    protectionStatus: String
