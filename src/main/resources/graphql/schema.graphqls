enum MetricType {
    DISK_READ
    DISK_WRITE
    NETWORK_IN
    NETWORK_OUT
}

type DailyMetricTotal {
    date: String!
    total: Float!
}

type VmMetricTotalResponse {
    vmId: ID!
    vmName: String!
    metricType: MetricType!
    dailyTotals: [DailyMetricTotal!]!
}

type SharedCostByServiceDto {
