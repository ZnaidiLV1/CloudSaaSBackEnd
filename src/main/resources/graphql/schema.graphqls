}

type BackupRecord {
    date: String
    status: String
    duration: String
    startTime: String
}

type DiskBackupHistory {
    diskName: String
    protectionStatus: String
    vaultName: String
    dataSourceType: String
    backupHistory: [BackupRecord!]!
}

type VmBackupHistoryResponse {
    vmId: ID!
    vmName: String!
    startDate: String!
    endDate: String!
    disks: [DiskBackupHistory!]!
}

type BackupVaultWithItems {
    vaultName: String!
    resourceGroup: String!
    location: String!
    storageType: String!
    protectedItems: [ProtectedItemInfo!]!
}

type ProtectedItemInfo {
    dataSourceName: String!
    protectionStatus: String!
    vmName: String
    vmId: Int
}

type DiskSizeAtTimeResponse {
    vmName: String!
    timestamp: String!
    diskTotalGB: Float!
    diskUsedPercent: Float!
    diskUsedGB: Float!
    diskFreeGB: Float!
}

type MissingMonthsResponse {
    results: [MonthResult!]!
